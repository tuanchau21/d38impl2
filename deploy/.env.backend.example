# d38shop — backend environment template
# From-scratch: copy to backend/.env (path relative to repo root; repo root = directory with backend/, frontend/, deploy/).
# Fill all values before first run. See plan/deployment-plan.md §4.6 and deploy/README.md.
# Do not commit real values.

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------------------------
# Database (MySQL HeatWave — Oracle Cloud Always Free)
# -----------------------------------------------------------------------------
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# -----------------------------------------------------------------------------
# Oracle Object Storage (S3-compatible API)
# -----------------------------------------------------------------------------
# Bucket and region
OCI_OBJECT_STORAGE_NAMESPACE=
OCI_OBJECT_STORAGE_BUCKET=
OCI_OBJECT_STORAGE_REGION=

# S3-compatible credentials (from OCI customer secret key / API key)
OCI_OBJECT_STORAGE_ACCESS_KEY=
OCI_OBJECT_STORAGE_SECRET_KEY=

# Optional: custom endpoint if not using default (e.g. https://objectstorage.REGION.oraclecloud.com)
# OCI_OBJECT_STORAGE_ENDPOINT=

# -----------------------------------------------------------------------------
# Admin API protection (admin-high-level-design.md §4, §5)
# -----------------------------------------------------------------------------
# API key for /api/admin/* (X-Admin-Key). Optional when login is used; allows scripts/CI.
ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# Admin login (session cookie). No secret required for server-side session lookup.
# HTTPS required in production for secure cookies (deployment-plan.md).
# -----------------------------------------------------------------------------

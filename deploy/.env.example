# d38shop — production environment template
# Copy to .env (or .env.production) on the server. Do not commit real values.

# -----------------------------------------------------------------------------
# Node
# -----------------------------------------------------------------------------
NODE_ENV=production

# -----------------------------------------------------------------------------
# Database (MySQL HeatWave — Oracle Cloud Always Free)
# -----------------------------------------------------------------------------
# Option A: single URL
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

# Option B: separate variables (use if your app reads these instead)
# MYSQL_HOST=
# MYSQL_PORT=3306
# MYSQL_USER=
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# -----------------------------------------------------------------------------
# Oracle Object Storage (S3-compatible API)
# -----------------------------------------------------------------------------
# Bucket and region
OCI_OBJECT_STORAGE_NAMESPACE=
OCI_OBJECT_STORAGE_BUCKET=
OCI_OBJECT_STORAGE_REGION=

# S3-compatible credentials (from OCI customer secret key / API key)
OCI_OBJECT_STORAGE_ACCESS_KEY=
OCI_OBJECT_STORAGE_SECRET_KEY=

# Optional: custom endpoint if not using default (e.g. https://objectstorage.REGION.oraclecloud.com)
# OCI_OBJECT_STORAGE_ENDPOINT=

# -----------------------------------------------------------------------------
# Admin API protection
# -----------------------------------------------------------------------------
# API key for /api/admin/* (e.g. X-Admin-Key header). Required in production.
ADMIN_API_KEY=

# -----------------------------------------------------------------------------
# Optional: public env (baked in at build time if used by frontend)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_APP_URL=https://your-domain.com
